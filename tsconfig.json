{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "ignoreDeprecations": "5.0",
    "baseUrl": ".",
    "paths": {
      "@types/*":      ["src/types/*"],
      "@engine/*":     ["src/engine/*"],
      "@components/*": ["src/components/*"],
      "@screens/*":    ["src/screens/*"],
      "@store/*":      ["src/store/*"],
      "@manifest/*":   ["src/manifest/*"],
      "@navigation/*": ["src/navigation/*"]
    }
  },
  "exclude": ["node_modules", "**/__tests__/**", "**/*.test.ts", "**/*.test.tsx"]
}
